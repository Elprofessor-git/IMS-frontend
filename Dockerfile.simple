# Dockerfile simple - assume que le build est fait en local
FROM nginx:alpine

# Installer curl pour les health checks
RUN apk add --no-cache curl

# Copier les fichiers pré-buildés depuis le répertoire local dist/
COPY dist/gestion-textile-frontend /usr/share/nginx/html

# Copier la configuration nginx
COPY nginx.conf /etc/nginx/nginx.conf

# Exposer le port
EXPOSE 80

# Commande de démarrage
CMD ["nginx", "-g", "daemon off;"]